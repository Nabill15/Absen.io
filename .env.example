# Environment: development atau production
APP_ENV=production

# Wajib: gunakan nilai acak minimal 32 karakter.
# Contoh generator: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters

# Pilih salah satu metode autentikasi admin.
# Metode yang direkomendasikan: hash password.
# Generator hash:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('PASSWORD_KUAT'))"
ADMIN_PASSWORD_HASH=
# Alternatif untuk secret manager platform:
ADMIN_PASSWORD=

# Gunakan volume persistent pada hosting, contoh /data/database.db
DATABASE_PATH=database.db
# Gunakan volume persistent atau object storage untuk deployment berskala besar.
UPLOAD_ROOT=instance/uploads

APP_TIMEZONE=Asia/Makassar
TIMEZONE_LABEL=WITA
FACE_MATCH_THRESHOLD=0.58

# Harus false pada production. Aplikasi juga memblokir simulasi ketika APP_ENV=production.
SIMULATION_ENABLED=false

# Set 1 jika aplikasi berada di belakang reverse proxy/load balancer tepercaya.
TRUST_PROXY=1
SESSION_MINUTES=30
MAX_CONTENT_LENGTH=3145728
LOG_LEVEL=INFO
PORT=8080
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
