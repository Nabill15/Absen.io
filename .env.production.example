# Salin nilai berikut ke Environment Variables platform hosting.
APP_ENV=production
SECRET_KEY=GANTI_DENGAN_SECRET_ACAK_MINIMAL_32_KARAKTER
ADMIN_PASSWORD_HASH=GANTI_DENGAN_HASH_DARI_RESET_ADMIN_PASSWORD_PY
ADMIN_PASSWORD=
DATABASE_PATH=/data/database.db
UPLOAD_ROOT=/data/uploads
APP_TIMEZONE=Asia/Makassar
TIMEZONE_LABEL=WITA
FACE_MATCH_THRESHOLD=0.58
SIMULATION_ENABLED=false
TRUST_PROXY=1
SESSION_MINUTES=30
MAX_CONTENT_LENGTH=3145728
LOG_LEVEL=INFO
PORT=8080
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
